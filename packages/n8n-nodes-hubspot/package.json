{
  "name": "@profitpad-inc/n8n-nodes-hubspot",
  "version": "0.1.34",
  "description": "n8n community node for the Hubspot API",
  "license": "MIT",
  "homepage": "",
  "keywords": [
    "n8n-community-node-package"
  ],
  "author": {
    "name": "Chris",
    "email": "chris.becher@profitpad.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/profitpad-inc/n8n-nodes.git",
    "directory": "packages/n8n-nodes-hubspot"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "release-it"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/nodes/HubSpot/HubspotApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/HubSpot/HubspotApi.node.js",
      "dist/nodes/HubSpot/HubspotApiTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.32.0",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
